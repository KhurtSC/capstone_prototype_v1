                    <tr class="empty-row"><td></td><td></td><td></td><td></td></tr>
                    <tr class="empty-row"><td></td><td></td><td></td><td></td></tr>
                    <tr class="empty-row"><td></td><td></td><td></td><td></td></tr>
                `
            }
        };

        // Render Controller Function
        function swithHistoryView(targetMode) {
            if (targetMode === 'visitors') {
                btnToggleVisitors.classList.add('active');
                btnToggleBooks.classList.remove('active');
                
                statCardLabel.textContent = viewsContent.visitors.label;
                statCardValue.textContent = viewsContent.visitors.value;
                tableHeaderBlock.innerHTML = viewsContent.visitors.headers;
                tableBodyBlock.innerHTML = viewsContent.visitors.body;
            } else {
                btnToggleBooks.classList.add('active');
                btnToggleVisitors.classList.remove('active');
                
                statCardLabel.textContent = viewsContent.books.label;
                statCardValue.textContent = viewsContent.books.value;
                tableHeaderBlock.innerHTML = viewsContent.books.headers;
                tableBodyBlock.innerHTML = viewsContent.books.body;
            }
        }

        // Action Trigger Listeners
        btnToggleVisitors.addEventListener('click', () => swithHistoryView('visitors'));
        btnToggleBooks.addEventListener('click', () => swithHistoryView('books'));
    </script>

</body>
</html>
