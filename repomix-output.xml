    <div class="java-toast-pill" id="globalJavaToastSystemComponent">Patron added successfully</div>

    <script>
        // Modal 1 Elements: Add Patron
        const addModal = document.getElementById('addPatronModal');
        const openAddModalBtn = document.getElementById('openAddPatronModalBtn');
        const closeXBtn = document.getElementById('closeAddModalXBtn');
        const closeCancelBtn = document.getElementById('closeAddModalCancelBtn');
        const addForm = document.getElementById('addPatronForm');

        // Modal 2 Elements: Temporary ID
        const tempModal = document.getElementById('tempIdModal');
        const openTempModalBtn = document.getElementById('openTempIdModalBtn');
        const closeTempXBtn = document.getElementById('closeTempModalXBtn');
        const closeTempCancelBtn = document.getElementById('closeTempModalCancelBtn');
        const closeTempDoneBtn = document.getElementById('closeTempModalDoneBtn');
        const tempForm = document.getElementById('tempIdForm');
        const tempFieldsFormContainer = document.getElementById('tempFieldsFormContainer');
        const tempActionBtnContainer = document.getElementById('tempActionBtnContainer');
        const tempQrCodeOutputContainer = document.getElementById('tempQrCodeOutputContainer');

        // Modal 3 Elements: Patron Info Directory Lookup
        const infoModal = document.getElementById('moreInfoModal');
        const closeInfoXBtn = document.getElementById('closeInfoModalXBtn');
        const infoStateToggleBtn = document.getElementById('infoStateToggleBtn');
        const infoToggleIcon = document.getElementById('infoToggleIcon');
        const infoPaneAvatarState = document.getElementById('infoPaneAvatarState');
        const infoPaneQrState = document.getElementById('infoPaneQrState');

        // Toast Component Target Selector
        const systemToast = document.getElementById('globalJavaToastSystemComponent');

        // Open Actions
        openAddModalBtn.addEventListener('click', () => addModal.classList.add('show'));
        openTempModalBtn.addEventListener('click', () => tempModal.classList.add('show'));

        // Table Row Parsing Event Wireup
        document.getElementById('patronsTableBody').addEventListener('click', (e) => {
            if (e.target.classList.contains('open-info-trigger')) {
                const row = e.target.closest('tr');
                
                // Read text values from table cells
                const cells = row.getElementsByTagName('td');
                document.getElementById('lblPatronId').innerText = cells[0].innerText;
                document.getElementById('lblFullName').innerText = cells[1].innerText;
                document.getElementById('lblAge').innerText = cells[2].innerText;
                document.getElementById('lblGender').innerText = cells[3].innerText;
                document.getElementById('lblCourse').innerText = cells[4].innerText;
                
                // Read detailed parameters from data attributes
                document.getElementById('lblPhoneNumber').innerText = row.getAttribute('data-phone');
                document.getElementById('lblAddress').innerText = row.getAttribute('data-address');
                document.getElementById('lblSchool').innerText = row.getAttribute('data-school');
                document.getElementById('lblAccountCreated').innerText = row.getAttribute('data-created');
                document.getElementById('lblActiveBorrows').innerText = row.getAttribute('data-borrows');
                
                // Reveal Modal
                infoModal.classList.add('show');
            }
        });

        // Close Dismissal Routines
        function dismissAddModal() {
            addModal.classList.remove('show');
            addForm.reset();
        }
        
        function dismissTempModal() {
            tempModal.classList.remove('show');
            setTimeout(() => {
                tempForm.reset();
                tempFieldsFormContainer.classList.remove('hidden');
                tempActionBtnContainer.classList.remove('hidden');
                tempQrCodeOutputContainer.classList.add('hidden');
            }, 200);
        }

        function dismissInfoModal() {
            infoModal.classList.remove('show');
            // Reset right pane profile visual toggle back to standard view upon closing
            setTimeout(() => {
                infoPaneAvatarState.classList.remove('hidden');
                infoPaneQrState.classList.add('hidden');
                infoToggleIcon.className = 'fas fa-qrcode';
            }, 200);
        }

        closeXBtn.addEventListener('click', dismissAddModal);
        closeCancelBtn.addEventListener('click', dismissAddModal);
        
        closeTempXBtn.addEventListener('click', dismissTempModal);
        closeTempCancelBtn.addEventListener('click', dismissTempModal);
        closeTempDoneBtn.addEventListener('click', dismissTempModal);

        closeInfoXBtn.addEventListener('click', dismissInfoModal);

        // Process Add Patron Submission with Toast Component Routing
        addForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // 1. Instantly close the modal card stack out of view
            dismissAddModal();
            
            // 2. Display the temporary bottom center floating toast element
            systemToast.classList.add('reveal-toast');
            
            // 3. Keep toast showing for exactly 3 seconds before sliding down
            setTimeout(() => {
                systemToast.classList.remove('reveal-toast');
            }, 3000);
        });

        // Process Temporary ID State Interchange Switching
        tempForm.addEventListener('submit', (e) => {
            e.preventDefault();
            tempFieldsFormContainer.classList.add('hidden');
            tempActionBtnContainer.classList.add('hidden');
            tempQrCodeOutputContainer.classList.remove('hidden');
        });

        // Handle More Info Right-Pane Micro-Interaction Toggling
        infoStateToggleBtn.addEventListener('click', () => {
            const isAvatarVisible = !infoPaneAvatarState.classList.contains('hidden');
            
            if (isAvatarVisible) {
                // Switch target to QR Layout Spec
                infoPaneAvatarState.classList.add('hidden');
                infoPaneQrState.classList.remove('hidden');
                infoToggleIcon.className = 'fas fa-user'; // Swap toggle item indicator control to Profile vector
            } else {
                // Return back to Profile Avatar Spec
                infoPaneQrState.classList.add('hidden');
                infoPaneAvatarState.classList.remove('hidden');
                infoToggleIcon.className = 'fas fa-qrcode'; // Reset interface option back to QR indicator icon
            }
        });

        // Outside Backdrop Click Triggers
        window.addEventListener('click', (e) => {
            if (e.target === addModal) dismissAddModal();
            if (e.target === tempModal) dismissTempModal();
            if (e.target === infoModal) dismissInfoModal();
        });
    </script>

