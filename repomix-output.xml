        const lblInfoLocation = document.getElementById('lblInfoLocation');
        const infoCoverCanvas = document.getElementById('infoCoverCanvas');
        const infoCoverFallbackTxt = document.getElementById('infoCoverFallbackTxt');

        const borrowerActiveViewBlock = document.getElementById('borrowerActiveViewBlock');
        const borrowerEmptyStateBlock = document.getElementById('borrowerEmptyStateBlock');
        const lblBorrowStatus = document.getElementById('lblBorrowStatus');
        const lblBorrowerName = document.getElementById('lblBorrowerName');
        const lblDateBorrowed = document.getElementById('lblDateBorrowed');
        const lblDateReturned = document.getElementById('lblDateReturned');
