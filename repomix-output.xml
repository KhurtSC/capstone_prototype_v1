                        </div>
                        <div class="receipt-row">
                            <span class="receipt-label">Borrower ID</span>
                            <span class="receipt-value">PL-26-1042</span>
                        </div>
                        
                        <hr class="receipt-divider">
                        
                        <div class="receipt-row">
                            <span class="receipt-label">Time Logged</span>
                            <span class="receipt-value">May 10, 2026 &bull; 10:15 am</span>
                        </div>
                        <div class="receipt-row">
                            <span class="receipt-label">Borrowing Mode</span>
                            <span class="receipt-value">
                                <span style="background-color: #e0f2fe; color: #0369a1; padding: 4px 12px; border-radius: 20px; font-size: 11.5px; font-weight: 700;">Take-Home</span>
                            </span>
