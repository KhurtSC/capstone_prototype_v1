                language: "English (Translated)",
                copies: "1",
                genre: "Fiction\nPsychological Novel\nClassics",
                location: "Aisle C / Rack 4",
                coverTxt: "No Longer\nHuman",
                coverClass: "",
                borrower: null
            },
            "2132 - 9348": {
                title: "Atomic Habits",
                author: "James Clear",
                barcode: "978-0735211292",
                publisher: "Avery",
                year: "2018",
                pages: "320",
                language: "English (English)",
                copies: "1",
                genre: "Self-Help\nNon-Fiction\nPsychology",
                location: "Aisle B / Rack 1",
                coverTxt: "Atomic\nHabits",
                coverClass: "",
                borrower: {
                    statusHtml: '<span class="status-dot dot-overdue"></span> Overdue',
                    name: "Sarah Jane V. Ramos\n(PL-24-3491)",
                    dateBorrowed: "Apr 20, 2026\n4:00 pm",
                    dateReturned: "-",
                    mode: "Take-Home",
