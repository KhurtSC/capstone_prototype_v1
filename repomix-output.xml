    <script>
        // Modal Trigger Selectors
        const bookModal = document.getElementById('addBookModal');
        const openBookModalBtn = document.getElementById('openAddBookModalBtn');
        const closeBookXBtn = document.getElementById('closeBookModalXBtn');
        
        // Multi-Step Wizard Track Components
        const wizardForm = document.getElementById('addBookWizardForm');
        const step1Content = document.getElementById('wizardStep1Content');
        const step2Content = document.getElementById('wizardStep2Content');
        const step3Content = document.getElementById('wizardStep3Content');
        const footerDock = document.getElementById('wizardFooterDock');
        
        // Action Buttons
        const btnBack = document.getElementById('btnWizardBack');
        const btnNext = document.getElementById('btnWizardNext');
        const progressFill = document.getElementById('wizardProgressFill');
        const stepDescriptor = document.getElementById('wizardStepDescriptor');

        // Language Selectors
        const langWrapper = document.getElementById('languageSelectDropdownWrapper');
        const langTriggerBtn = document.getElementById('langSelectTriggerBtn');
        const langTextLabel = document.getElementById('langSelectTextLabel');
        const langChevronIcon = document.getElementById('langSelectChevronIcon');
        const langOverlayPanel = document.getElementById('langDropdownOverlayPanel');
        const hiddenLangInput = document.getElementById('txtHiddenLanguageInput');

        // Genre Selectors
        const genreWrapper = document.getElementById('genreSelectDropdownWrapper');
        const genreTriggerBtn = document.getElementById('genreSelectTriggerBtn');
        const genreTextLabel = document.getElementById('genreSelectTextLabel');
        const genreChevronIcon = document.getElementById('genreSelectChevronIcon');
        const genreOverlayPanel = document.getElementById('genreDropdownOverlayPanel');
        const hiddenGenreInput = document.getElementById('txtHiddenGenreInput');
        const genrePills = document.querySelectorAll('.genre-pill-item');

        const systemToast = document.getElementById('globalJavaToastSystemComponent');

        let currentStep = 1;
        let selectedGenres = [];

        openBookModalBtn.addEventListener('click', () => {
            bookModal.classList.add('show');
        });

        function dismissBookModal() {
            bookModal.classList.remove('show');
            setTimeout(() => {
                wizardForm.reset();
                closeLanguageDropdownRoutine();
                closeGenreDropdownRoutine();
                
                langTextLabel.textContent = "Select";
                langTextLabel.classList.add('placeholder-active');
                hiddenLangInput.value = "";
                
                genreTextLabel.textContent = "Select (Multiple)";
                genreTextLabel.classList.add('placeholder-active');
                hiddenGenreInput.value = "";
                selectedGenres = [];
                genrePills.forEach(pill => pill.classList.remove('selected-active'));

                navigateToStep(1);
            }, 200);
        }

        closeBookXBtn.addEventListener('click', dismissBookModal);

        function navigateToStep(step) {
            currentStep = step;
            
            if (currentStep === 1) {
                step1Content.classList.remove('hidden');
                step2Content.classList.add('hidden');
                step3Content.classList.add('hidden');
                footerDock.className = "wizard-footer-controls step-1-layout";
                btnBack.classList.add('hidden');
                btnNext.textContent = "Next";
                btnNext.type = "button";
                progressFill.style.width = "33.33%";
                stepDescriptor.textContent = "Step 1: Core Information";
                toggleValidationStates(1);
            } 
            else if (currentStep === 2) {
                step1Content.classList.add('hidden');
                step2Content.classList.remove('hidden');
                step3Content.classList.add('hidden');
                footerDock.className = "wizard-footer-controls step-2-layout";
                btnBack.classList.remove('hidden');
                btnNext.textContent = "Next"; 
                btnNext.type = "button";
                progressFill.style.width = "66.66%";
                stepDescriptor.textContent = "Step 2: Bibliographic Details";
                toggleValidationStates(2);
            }
            else if (currentStep === 3) {
                step1Content.classList.add('hidden');
                step2Content.classList.add('hidden');
                step3Content.classList.remove('hidden');
                footerDock.className = "wizard-footer-controls step-2-layout";
                btnBack.classList.remove('hidden');
                btnNext.textContent = "Finish"; 
                btnNext.type = "submit";
                progressFill.style.width = "100%"; // 100% full bar on the final step
                stepDescriptor.textContent = "Step 3: Inventory & Location";
                toggleValidationStates(3);
            }
        }

        function toggleValidationStates(activeStep) {
            const step2Fields = [
                document.getElementById('txtPublisher'),
                document.getElementById('txtYearPublished'),
                document.getElementById('txtPages'),
                hiddenLangInput,
                hiddenGenreInput
            ];
            const step3Fields = [
                document.getElementById('txtTotalCopies'),
                document.getElementById('selAisle'),
                document.getElementById('selRack')
            ];
            step2Fields.forEach(field => { if (field) field.required = (activeStep === 2); });
            step3Fields.forEach(field => { if (field) field.required = (activeStep === 3); });
        }

        btnNext.addEventListener('click', (e) => {
            if (currentStep === 1) {
                const inputsValid = step1Content.querySelector('input:invalid') === null;
                if (inputsValid) navigateToStep(2); else wizardForm.reportValidity();
            } else if (currentStep === 2) {
                const inputsValid = step2Content.querySelector('input:invalid') === null && hiddenLangInput.value !== "" && hiddenGenreInput.value !== "";
                if (inputsValid) navigateToStep(3); else wizardForm.reportValidity();
            }
        });

        btnBack.addEventListener('click', () => {
            if (currentStep === 2) {
                closeLanguageDropdownRoutine();
                closeGenreDropdownRoutine();
                navigateToStep(1);
            } else if (currentStep === 3) {
                navigateToStep(2);
            }
        });

        langTriggerBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (langWrapper.contains(e.target) && langWrapper.classList.contains('active-open')) {
                closeLanguageDropdownRoutine();
            } else {
                closeGenreDropdownRoutine(); 
                langWrapper.classList.add('active-open');
                langOverlayPanel.classList.remove('hidden');
                langChevronIcon.className = "fas fa-chevron-right";
            }
        });

        function closeLanguageDropdownRoutine() {
            langWrapper.classList.remove('active-open');
            langOverlayPanel.classList.add('hidden');
            langChevronIcon.className = "fas fa-chevron-down";
        }

        langOverlayPanel.addEventListener('click', (e) => {
            const targetOption = e.target.closest('.custom-dropdown-option-item');
            if (targetOption) {
                const languageSelectedValue = targetOption.getAttribute('data-value');
                langTextLabel.textContent = languageSelectedValue;
                langTextLabel.classList.remove('placeholder-active');
                hiddenLangInput.value = languageSelectedValue;
                closeLanguageDropdownRoutine();
            }
        });

        genreTriggerBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (genreWrapper.contains(e.target) && genreWrapper.classList.contains('active-open')) {
                closeGenreDropdownRoutine();
            } else {
                closeLanguageDropdownRoutine(); 
                genreWrapper.classList.add('active-open');
                genreOverlayPanel.classList.remove('hidden');
                genreChevronIcon.className = "fas fa-chevron-right";
            }
        });

        function closeGenreDropdownRoutine() {
            genreWrapper.classList.remove('active-open');
            genreOverlayPanel.classList.add('hidden');
            genreChevronIcon.className = "fas fa-chevron-down";
        }

        genrePills.forEach(pill => {
            pill.addEventListener('click', (e) => {
                e.stopPropagation(); 
                const pillValue = pill.getAttribute('data-value');
                if (pill.classList.contains('selected-active')) {
                    pill.classList.remove('selected-active');
                    selectedGenres = selectedGenres.filter(genre => genre !== pillValue);
                } else {
                    pill.classList.add('selected-active');
                    selectedGenres.push(pillValue);
                }
                if (selectedGenres.length > 0) {
                    genreTextLabel.textContent = selectedGenres.join(', ');
                    genreTextLabel.classList.remove('placeholder-active');
                    hiddenGenreInput.value = JSON.stringify(selectedGenres);
                } else {
                    genreTextLabel.textContent = "Select (Multiple)";
                    genreTextLabel.classList.add('placeholder-active');
                    hiddenGenreInput.value = "";
                }
            });
        });

        wizardForm.addEventListener('submit', (e) => {
            e.preventDefault();
            dismissBookModal();
            systemToast.classList.add('reveal-toast');
            setTimeout(() => { systemToast.classList.remove('reveal-toast'); }, 3000);
        });

        // ==========================================================================
        // Repository Database Mapping Router Logic
        // ==========================================================================
        const catalogMockDatabase = {
            "2342 - 6931": {
