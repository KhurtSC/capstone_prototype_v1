                </div>

                <div id="step2Container" class="step-container hidden">
                    <img src="scan.png" alt="Scan Book Barcode" class="scanner-graphic">
                    <h2>Awaiting Book Barcode Input</h2>
                    <p>Please scan the book's barcode</p>
