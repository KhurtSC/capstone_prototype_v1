    <script>
        // Progress HUD Tracks
        const bar1 = document.getElementById('bar1');
        const bar2 = document.getElementById('bar2');
        const bar3 = document.getElementById('bar3');
        const progressText = document.getElementById('progressText');

        // Containers
        const step1Container = document.getElementById('step1Container');
        const step2Container = document.getElementById('step2Container');
        const step3Container = document.getElementById('step3Container');

        // Inputs
        const patronBarcodeField = document.getElementById('patronBarcodeField');
        const bookBarcodeField = document.getElementById('bookBarcodeField');

        // Internal State Variable Track
        let currentStep = 1;

        // Step 1 Field Action Submission
        patronBarcodeField.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && patronBarcodeField.value.trim() !== '') {
                e.preventDefault();
                
                currentStep = 2;
                step1Container.classList.add('hidden');
                step2Container.classList.remove('hidden');
                
                bar1.classList.remove('active');
                bar2.classList.add('active');
                progressText.textContent = 'Step 2: Scan Book';
                
                setTimeout(() => bookBarcodeField.focus(), 50);
            }
        });

        // Step 2 Field Action Submission
        bookBarcodeField.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && bookBarcodeField.value.trim() !== '') {
                e.preventDefault();
                
                currentStep = 3;
                step2Container.classList.add('hidden');
                step3Container.classList.remove('hidden');
                
                bar2.classList.remove('active');
                bar3.classList.add('active');
                progressText.textContent = 'Transaction Complete';
            }
        });

        // High-Speed Global Key Listener to recycle the workflow on Spacebar hit
        window.addEventListener('keydown', (e) => {
            if (e.key === ' ' && currentStep === 3) {
                e.preventDefault(); // Prevents spacebar from standard window scrolling down
                
                // Clear state inputs cleanly
                patronBarcodeField.value = '';
                bookBarcodeField.value = '';
                
                // Reset layouts back to step 1 state mapping rules
                currentStep = 1;
                step3Container.classList.add('hidden');
                step1Container.classList.remove('hidden');
                
                bar3.classList.remove('active');
                bar1.classList.add('active');
                progressText.textContent = 'Step 1: Scan Patron';
                
                // Keep cursor focused right inside entry lane
                setTimeout(() => patronBarcodeField.focus(), 50);
            }
        });
    </script>

</body>
</html>
