    <script>
        // Modal Element selectors
        const announceModal = document.getElementById('announcementModal');
        const openAnnounceModalBtn = document.getElementById('openAnnounceModalBtn');
        const closeAnnounceModalBtn = document.getElementById('closeAnnounceModalBtn');
        const announcementForm = document.getElementById('announcementForm');

        // Form Inputs
        const announceHeading = document.getElementById('announceHeading');
        const announceBody = document.getElementById('announceBody');
        const hiddenFileInput = document.getElementById('hiddenFileInput');

        // Drag and Drop workspace interfaces
        const dropZoneContainer = document.getElementById('dropZoneContainer');
        const uploadMetaContent = document.getElementById('uploadMetaContent');
        const announcementsFeedBox = document.getElementById('announcementsFeedBox');

        let stagedFilesList = [];

        // Toggle Modal Trigger Actions
        openAnnounceModalBtn.addEventListener('click', () => {
            announceModal.classList.add('show');
        });

        function dismissAnnouncementModal() {
            announceModal.classList.remove('show');
            setTimeout(() => {
                announcementForm.reset();
                resetUploadZoneDefaultUI();
            }, 200);
        }

        closeAnnounceModalBtn.addEventListener('click', dismissAnnouncementModal);

        // ==========================================================================
        // High-Fidelity Front-End Drag and Drop Validation Simulator Route
        // ==========================================================================
        ['dragenter', 'dragover'].forEach(eventName => {
            dropZoneContainer.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropZoneContainer.classList.add('dragover-active');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZoneContainer.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropZoneContainer.classList.remove('dragover-active');
            }, false);
        });

        dropZoneContainer.addEventListener('drop', (e) => {
            const transferData = e.dataTransfer;
            const receivedFiles = transferData.files;
            handleFileAttachmentsInjection(receivedFiles);
        });

        hiddenFileInput.addEventListener('change', (e) => {
            handleFileAttachmentsInjection(hiddenFileInput.files);
        });

        function handleFileAttachmentsInjection(files, isAppend = true) {
            // Append newly chosen files into the existing file track array instead of overwriting
            if (isAppend && files && files.length > 0) {
                const combinedFiles = [...stagedFilesList, ...Array.from(files)];
                stagedFilesList = combinedFiles.slice(0, 5); // Max 5 items restriction boundary
            }

            if(stagedFilesList.length > 0) {
                // Build a dynamic list that perfectly copies your target wireframe image design layout specs
                let listHtml = `
                    <h4 style="font-size: 15px; font-weight: 700; color: var(--text-dark); margin-bottom: 2px;">Attachments</h4>
                    <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 8px 0 10px 0;">
                    <div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
                `;

                stagedFilesList.forEach((file, index) => {
                    // Added .staged-file-row layout hook class and inline stagger tracking animation delays
                    listHtml += `
                        <div class="staged-file-row" style="display: flex; justify-content: space-between; align-items: center; font-size: 14px; color: #5a5a5a; animation-delay: ${index * 0.04}s;">
                            <span>${file.name}</span>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <i class="far fa-check-circle" style="color: #22c55e; font-size: 15px;"></i>
                                <i class="fas fa-times remove-staged-file-btn" data-index="${index}" style="color: #9ca3af; cursor: pointer; font-size: 14px;"></i>
                            </div>
                        </div>
                    `;
                });

                listHtml += `</div>`;
                
                // Pivot structure alignment style hooks slightly to hold multi-row file rows cleanly
                dropZoneContainer.style.alignItems = 'flex-start';
                uploadMetaContent.innerHTML = listHtml;

                // Wire up close/remove file click handlers inside the newly injected nodes
                const removeActionElements = uploadMetaContent.querySelectorAll('.remove-staged-file-btn');
                removeActionElements.forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation(); // Stops label default browser directory trigger popup windows
                        e.preventDefault();
                        
                        const idxToRemove = parseInt(btn.getAttribute('data-index'));
                        stagedFilesList.splice(idxToRemove, 1);
                        
                        if (stagedFilesList.length === 0) {
                            resetUploadZoneDefaultUI();
                        } else {
                            // Re-render UI frame track accurately without doubling arrays up
                            handleFileAttachmentsInjection([], false);
                        }
                    });
                });
            }
        }

        function resetUploadZoneDefaultUI() {
            stagedFilesList = [];
            dropZoneContainer.style.alignItems = 'center';
            uploadMetaContent.innerHTML = `
                <h4 id="uploadBoxTitle">Attachments</h4>
                <p id="uploadBoxSubtext">Drag/Drop files here. You can upload a maximum of 5 files, 5MB each.</p>
            `;
        }

        // Prepend new feed layout row entry directly on submit event route mapping
        announcementForm.addEventListener('submit', (e) => {
            e.preventDefault();

            const headingTxt = announceHeading.value;
            const bodyTxt = announceBody.value;
            
            // FIX: Dynamically generate multiple download anchor links for ALL uploaded items
            let attachmentsOutputHtml = "None";
            if (stagedFilesList.length > 0) {
                attachmentsOutputHtml = stagedFilesList.map(file => `
                    <a class="attachment-link"><i class="fas fa-paperclip" style="font-size:12px; margin-right:4px;"></i>${file.name}</a>
                `).join('');
            }

            const newCardHtml = `
                <div class="date-divider">May 11, 2026</div>
                <div class="announcement-card">
                    <div class="card-header">
                        <div class="card-title-group">
                            <i class="fas fa-bullhorn megaphone-icon"></i>
                            <h3>${headingTxt}</h3>
                        </div>
                        <div class="card-actions">
                            <a>Edit</a> | <a>Delete</a>
                        </div>
                    </div>
                    <div class="card-body">
                        ${bodyTxt}
                    </div>
                    <div class="card-footer">
                        Attachments: ${attachmentsOutputHtml}
                    </div>
                </div>
            `;

            // Insert into top lane channel cleanly
            announcementsFeedBox.insertAdjacentHTML('afterbegin', newCardHtml);
            dismissAnnouncementModal();
        });

        // Close modal when user clicks on background overlay space bounding areas
        window.addEventListener('click', (e) => {
            if (e.target === announceModal) dismissAnnouncementModal();
        });
    </script>

</body>
</html>
