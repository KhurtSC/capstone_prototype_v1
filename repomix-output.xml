        const lblProcessedBy = document.getElementById('lblProcessedBy');
        const lblAssessment = document.getElementById('lblAssessment');
        const borrowCoverCanvas = document.getElementById('borrowCoverCanvas');
        const borrowCoverFallbackTxt = document.getElementById('borrowCoverFallbackTxt');

        document.querySelector('table tbody').addEventListener('click', (e) => {
            const clickTarget = e.target;
            if (clickTarget.classList.contains('action-link')) {
                e.preventDefault();
                const selectedRow = clickTarget.closest('tr');
                if (!selectedRow || selectedRow.classList.contains('empty-row')) return;
                
                const bookIdKey = selectedRow.cells[0].textContent.trim();
                const bookRecord = catalogMockDatabase[bookIdKey];
                
                if (bookRecord) {
                    lblInfoBookId.textContent = bookIdKey;
                    lblInfoTitle.textContent = bookRecord.title;
                    lblInfoAuthor.textContent = bookRecord.author;
                    lblInfoBarcode.textContent = bookRecord.barcode;
                    lblInfoPublisher.textContent = bookRecord.publisher;
                    lblInfoYear.textContent = bookRecord.year;
                    lblInfoPages.textContent = bookRecord.pages;
                    lblInfoLanguage.textContent = bookRecord.language;
                    lblInfoCopies.textContent = bookRecord.copies;
                    lblInfoGenre.textContent = bookRecord.genre;
                    lblInfoLocation.textContent = bookRecord.location;
                    
                    infoCoverFallbackTxt.textContent = bookRecord.coverTxt;
                    infoCoverCanvas.className = "info-cover-preview " + bookRecord.coverClass;
                    
                    if (bookRecord.borrower) {
                        borrowerActiveViewBlock.classList.remove('hidden');
                        borrowerEmptyStateBlock.classList.add('hidden');
                        lblBorrowStatus.innerHTML = bookRecord.borrower.statusHtml;
                        lblBorrowerName.textContent = bookRecord.borrower.name;
                        lblDateBorrowed.textContent = bookRecord.borrower.dateBorrowed;
                        lblDateReturned.textContent = bookRecord.borrower.dateReturned;
                        lblBorrowMode.textContent = bookRecord.borrower.mode;
                        lblProcessedBy.textContent = bookRecord.borrower.processedBy;
                        lblAssessment.textContent = bookRecord.borrower.assessment;
                        
                        borrowCoverFallbackTxt.textContent = bookRecord.coverTxt;
                        borrowCoverCanvas.className = "info-cover-preview " + bookRecord.coverClass;
                    } else {
                        borrowerActiveViewBlock.classList.add('hidden');
                        borrowerEmptyStateBlock.classList.remove('hidden');
                    }
                    
                    activateDetailPanelTab('info');
                    infoBookModal.classList.add('show');
                }
            }
        });

        function activateDetailPanelTab(tabMode) {
            if (tabMode === 'info') {
                tabBtnInfo.classList.add('active');
                tabBtnBorrower.classList.remove('active');
                infoTabContentPanel.classList.remove('hidden');
                borrowerTabContentPanel.classList.add('hidden');
            } else {
                tabBtnInfo.classList.remove('active');
                tabBtnBorrower.classList.add('active');
                infoTabContentPanel.classList.add('hidden');
                borrowerTabContentPanel.classList.remove('hidden');
            }
        }

        tabBtnInfo.addEventListener('click', () => activateDetailPanelTab('info'));
        tabBtnBorrower.addEventListener('click', () => activateDetailPanelTab('borrower'));

        function dismissBookInfoModal() {
            infoBookModal.classList.remove('show');
        }

        closeInfoModalXBtn.addEventListener('click', dismissBookInfoModal);

        window.addEventListener('click', (e) => {
            if (!langWrapper.contains(e.target)) closeLanguageDropdownRoutine();
            if (!genreWrapper.contains(e.target)) closeGenreDropdownRoutine();
            if (e.target === bookModal) dismissBookModal();
