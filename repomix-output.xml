        };

        const infoBookModal = document.getElementById('infoBookModal');
        const closeInfoModalXBtn = document.getElementById('closeInfoModalXBtn');
        const tabBtnInfo = document.getElementById('tabBtnInfo');
        const tabBtnBorrower = document.getElementById('tabBtnBorrower');
        const infoTabContentPanel = document.getElementById('infoTabContentPanel');
        const borrowerTabContentPanel = document.getElementById('borrowerTabContentPanel');

        const lblInfoBookId = document.getElementById('lblInfoBookId');
        const lblInfoTitle = document.getElementById('lblInfoTitle');
        const lblInfoAuthor = document.getElementById('lblInfoAuthor');
        const lblInfoBarcode = document.getElementById('lblInfoBarcode');
        const lblInfoPublisher = document.getElementById('lblInfoPublisher');
        const lblInfoYear = document.getElementById('lblInfoYear');
        const lblInfoPages = document.getElementById('lblInfoPages');
        const lblInfoLanguage = document.getElementById('lblInfoLanguage');
        const lblInfoCopies = document.getElementById('lblInfoCopies');
